# Copy this file to .env and adjust as needed.
# LLM_MODE=mock runs the entire pipeline with canned responses - no GPU or
# network access required. Switch to LLM_MODE=vllm on the AMD Developer Cloud
# notebook once a vLLM OpenAI-compatible server is running.
LLM_MODE=mock

# vLLM OpenAI-compatible server (only used when LLM_MODE=vllm)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed
VLLM_MODEL_INTENT=Qwen/Qwen3-8B
VLLM_MODEL_SYNTHESIS=Qwen/Qwen3-8B
VLLM_MODEL_THEMES=Qwen/Qwen3-8B
VLLM_MODEL_ORCHESTRATOR=Qwen/Qwen3-8B
VLLM_MODEL_SPECIALIST=Qwen/Qwen3-8B
VLLM_MODEL_REPORT=Qwen/Qwen3-8B
LLM_REQUEST_TIMEOUT=60

# Server Configuration
HOST=127.0.0.1
PORT=8001
LOG_LEVEL=info

# Session Configuration
SESSION_MAX_AGE_HOURS=4
SESSION_MAX_HISTORY=10

# CSV / Log batch limits
MAX_CSV_ROWS=50000
MAX_CSV_MB=50

# Survey Pack Tool Configuration
MAX_OPEN_TEXT_SAMPLE=150
MAX_THEME_COUNT=8
ANOMALY_Z_THRESHOLD=2.0
MIN_SEGMENT_SIZE=10

# Governance Pack - Presidio / PII Configuration
PII_SCORE_THRESHOLD=0.4
PRESIDIO_SPACY_MODEL=en_core_web_sm
